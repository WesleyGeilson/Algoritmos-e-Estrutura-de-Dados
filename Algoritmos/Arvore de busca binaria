// Vamos aprofundar um pouco mais o estudo das arvores e adicionar um ponteiro a mais para ela, um ponteiro que aponta para o seu respectivo Pai

struct nó {
    int val;
    struct nó *esq, *dir, *pai;
}Nó

// Algoritmo ITERATIVO que percorre toda a arvore e imprime ela
Imprime_arvore (p) {
    q1 = p;
    q2 = Nulo;

    Enquanto ( q1 != Nulo ) {
        // CASO 1: Descendo na árvore (vindo do pai)
        Se ( q2 = q1->pai ) {
            q2 = q1;
            Se ( q1->esq != Nulo ) {
                q1 = q1->esq;
            } 
            Senao {
                Imprime ( q1->val ); // Visita o nó se não houver esquerda
                Se ( q1->dir != Nulo ) {
                    q1 = q1->dir;
                } 
                Senao {
                    q1 = q1->pai;
                    // aqui está faltando algo?
                }
            }
        }
        // CASO 2: Subindo da esquerda
        Senao Se ( q2 = q1->esq ) {
            q2 = q1;
            Imprime ( q1->val ); // Visita após retornar da subárvore esquerda
            Se ( q1->dir != Nulo ) {
                q1 = q1->dir;
            } 
            Senao {
                q1 = q1->pai;
            }
        }
        // CASO 3: Subindo da direita
        Senao Se ( q2 = q1->dir ) {
            q2 = q1;
            q1 = q1->pai;
        }
    }
}

//Algoritmo RECURSIVO que descobre se uma arvore é ou não uma arvore de busca
Isbst(p,min,max){ // min e max iniciados com -infinito e +infinito respectivamente
    Se(p == NULO){
        retorna verdadeiro // a arvore é binaria de busca
    }
    Se(p->val <= min ou p->val >= max){
        imprime( "não é BST")
        retorna
    }
    senão{
        Isbst(p->esq, min, p->val)
        Isbst(p->dir, p->val, max)
    }

} 

//Algoritmo RECURSIVO que encontra o maior elemento k e imprime ele
findAndprint(p,k){
    Se(p == NULO){
        retorna // n esta na arvore o elemento k
    }
    Se(p->val == k){
        imprime(k)
        retorna
    }
    senao{
        Se(p-> val > k ){
            findAndprint(p->esq, k)
        }
        Se(p-> val < k ){
            findAndprint(p->dir, k)
        }
    }
}

// Algoritmo que usa pilha para contar quantos elementos tem na lista 
count_elements(pt){
    Se( pt == NULO){
        retorna
    }
    Senão{
        count = 0
        p = {} // pilha vazia // 1
        push(p,pt)
        Enquanto(p não estiver vazia){
            count++ // hotspot
            q = pop(p,pt)
            Se(q-> esq != NULO){
                push(q->esq, pt)
            }
            Se(q-> dir != NULO){
                push(q->dir, pt)
            }
        }
    }
}

